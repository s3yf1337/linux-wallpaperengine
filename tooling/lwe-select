#!/usr/bin/env bash
# TUI wallpaper picker backed by ~/.cache/lwe_index.json (built by lwe-index).
# Fuzzy-search by title/type/tags/id, Enter launches on the desktop.
# Requires: fzf, jq. Forces bash for fzf preview even when $SHELL is fish.
set -euo pipefail

INDEX="$HOME/.cache/lwe_index.json"
if [ ! -f "$INDEX" ]; then
  if command -v lwe-index >/dev/null 2>&1; then
    lwe-index --rebuild >/dev/null
  else
    echo "missing $INDEX and lwe-index not in PATH" >&2
    exit 1
  fi
fi

command -v fzf >/dev/null 2>&1 || { echo "fzf required" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "jq required" >&2; exit 1; }

export SHELL=/bin/bash

pick=$(
  jq -r '.[] | "\(.title) [\(.type)] \(.id)"' "$INDEX" \
  | fzf --with-nth 1 \
        --preview-window 'right:40%:wrap' \
        --preview 'id=$(echo {} | grep -oE "[0-9]+$"); d="$HOME/.local/share/Steam/steamapps/workshop/content/431960/$id"; prev="$d/preview.jpg"; [ -f "$prev" ] && echo "file://$prev"; echo; sed -n "1,16p" "$d/project.json" 2>/dev/null' \
        --prompt 'wallpaper> ' || true
)

[ -z "$pick" ] && { echo "cancelled"; exit 0; }
id="${pick##* }"
echo "launching $id ..."
exec lwe-launch "$id"
